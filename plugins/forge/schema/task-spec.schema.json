{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/connor-worthen4/forge/blob/main/plugins/forge/schema/task-spec.schema.json",
  "title": "Forge Task Spec",
  "description": "Frontmatter contract for a forge task spec markdown file. The YAML frontmatter, parsed to an object, validates against this schema. The markdown body is free-form and not validated.",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "title", "type", "autonomy_tier", "acceptance_criteria"],
  "properties": {
    "id": {
      "type": "string",
      "description": "Stable unique id, format <type>-<ULID-or-shorthash>. Reused as the run dir name and inside the branch name, so filesystem- and branch-safe.",
      "pattern": "^(fix|build|audit|refactor|investigate|chore)-[0-9A-Za-z]{6,26}$"
    },
    "title": {
      "type": "string",
      "minLength": 1,
      "description": "Short human title."
    },
    "type": {
      "type": "string",
      "description": "The kind of work.",
      "enum": ["fix", "build", "audit", "refactor", "investigate", "chore"]
    },
    "autonomy_tier": {
      "type": "integer",
      "description": "0 = read-only report; 1 = branch + PR into base, never merges (default); 2 = gated, pause for human plan approval before building.",
      "enum": [0, 1, 2]
    },
    "acceptance_criteria": {
      "type": "array",
      "description": "Explicit, checkable list that verify and review test against. Concrete and verifiable, not vague.",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "scope": {
      "description": "Files/dirs/modules likely in play, or the literal 'unknown - investigate'.",
      "oneOf": [
        {
          "type": "string",
          "minLength": 1
        },
        {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      ]
    },
    "constraints": {
      "type": "array",
      "description": "Invariants to preserve or things not to touch.",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "context_refs": {
      "type": "array",
      "description": "Pointers (paths, URLs, related PRs) to read. Never inline content.",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "priority": {
      "type": "string",
      "description": "Queue ordering; P0 is most urgent.",
      "enum": ["P0", "P1", "P2", "P3"]
    },
    "base_branch": {
      "type": "string",
      "minLength": 1,
      "description": "Branch the eventual PR targets. Defaults to the project base (develop)."
    },
    "source": {
      "type": "object",
      "description": "Provenance of the task.",
      "additionalProperties": false,
      "required": ["kind", "ref"],
      "properties": {
        "kind": {
          "type": "string",
          "enum": ["cli", "file", "issue", "notion", "slack", "email", "api", "other"]
        },
        "ref": {
          "type": "string",
          "minLength": 1,
          "description": "Originating URL, path, or id."
        }
      }
    }
  },
  "allOf": [
    {
      "if": { "properties": { "type": { "const": "fix" } }, "required": ["type"] },
      "then": { "properties": { "id": { "pattern": "^fix-" } } }
    },
    {
      "if": { "properties": { "type": { "const": "build" } }, "required": ["type"] },
      "then": { "properties": { "id": { "pattern": "^build-" } } }
    },
    {
      "if": { "properties": { "type": { "const": "audit" } }, "required": ["type"] },
      "then": { "properties": { "id": { "pattern": "^audit-" } } }
    },
    {
      "if": { "properties": { "type": { "const": "refactor" } }, "required": ["type"] },
      "then": { "properties": { "id": { "pattern": "^refactor-" } } }
    },
    {
      "if": { "properties": { "type": { "const": "investigate" } }, "required": ["type"] },
      "then": { "properties": { "id": { "pattern": "^investigate-" } } }
    },
    {
      "if": { "properties": { "type": { "const": "chore" } }, "required": ["type"] },
      "then": { "properties": { "id": { "pattern": "^chore-" } } }
    }
  ]
}
